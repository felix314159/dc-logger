# Copy this file to `.env`, then edit values.

DISCORD_BOT_TOKEN="<REDACTED_BOT_TOKEN>"
DISCORD_LOG_DB="./database/database.db"

# First run: keep "*" to discover guild IDs from startup logs.
# After discovery, pin to one or more comma-separated guild IDs.
DISCORD_SYNC_GUILD_IDS="*"

# Optional startup backfill budget.
DISCORD_BACKFILL_MAX_PAGES_PER_RUN=0
DISCORD_BACKFILL_MAX_MINUTES=0

# Optional attachment text extraction limit in bytes (default 1 MiB).
DISCORD_ATTACHMENT_TEXT_MAX_BYTES=1048576
